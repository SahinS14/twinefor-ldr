    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.9",
    "@types/passport-jwt": "^3.0.8",
    "@types/uuid": "^9.0.0",
    "ts-node": "^10.9.1",
